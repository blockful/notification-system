######Consumers env
TELEGRAM_BOT_TOKEN= # Telegram bot token
ANTICAPTURE_DATABASE_URL= # Database connection string (PostgreSQL)
SUBSCRIPTION_SERVER_URL=http://localhost:3001

######Logic System env
DATABASE_URL= # Database connection string (PostgreSQL)
API_URL=http://localhost:3000/api/notifications # API endpoint URL
TRIGGER_INTERVAL=60000 # Interval in milliseconds (default: 60000 = 1 minute)
PROPOSAL_STATUS=active # Proposal status to filter (pending, active, succeeded, defeated, executed, canceled, queued, expired)

#####Dispatcher env
PORT=3002
NODE_ENV=development 

#####Subscription Server env
PORT=3001
NODE_ENV=development 
