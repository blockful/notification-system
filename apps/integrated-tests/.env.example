# Integration Tests Environment Variables

# RabbitMQ (optional - uses test container if not provided)
TEST_RABBITMQ_URL=amqp://localhost:5672

# Telegram Configuration
# To send real Telegram messages during tests:
# 1. Set SEND_REAL_TELEGRAM=true
# 2. Provide your Telegram bot token
SEND_REAL_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Slack Configuration
# To send real Slack messages during tests:
# 1. Install your Slack app in a workspace via OAuth
# 2. Get the workspace_id and bot_token from the database
# 3. Get a channel ID:
#    - For public/private channels: Copy the channel ID from Slack (starts with C)
#    - For DMs: Open a DM with the bot, the channel ID starts with D
# 4. Set SEND_REAL_SLACK=true and provide all credentials below
SEND_REAL_SLACK=false
SLACK_WORKSPACE_ID=T1234567890    # Your workspace ID (starts with T)
SLACK_BOT_TOKEN=xoxb-...          # Bot token from OAuth installation
SLACK_TEST_CHANNEL_ID=D1234567890 # Channel ID (C for channel, D for DM)