######Test Configuration
# Configurações específicas para os testes integrados
TEST_ENVIRONMENT=development

######Consumers env
TELEGRAM_BOT_TOKEN= # Token do bot do Telegram (pode ser mock para testes)
ANTICAPTURE_DATABASE_URL= # URL de conexão com o banco de dados do consumer
SUBSCRIPTION_SERVER_URL=http://localhost:3001 # URL do servidor de subscrição

######Logic System env
DATABASE_URL= # URL de conexão com o banco de dados (PostgreSQL)
API_URL=http://localhost:3002/notifications # URL da API do dispatcher
TRIGGER_INTERVAL=5000 # Intervalo em milissegundos para o logic system verificar atualizações (5s para testes)
PROPOSAL_STATUS=active # Status da proposta para filtrar 

#####Dispatcher env
PORT=3002 # Porta do dispatcher
NODE_ENV=development 

#####Subscription Server env
PORT=3001 # Porta do servidor de subscrição
NODE_ENV=development
