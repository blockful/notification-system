{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "codegen": {
      "inputs": ["**/*.graphql", "codegen.yaml"],
      "outputs": ["src/gql/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
