{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@consumers/*": ["apps/consumers/src/*"],
      "@logic-system/*": ["apps/logic-system/src/*"],
      "@dispatcher/*": ["apps/dispatcher/src/*"],
      "@subscription-server/*": ["apps/subscription-server/src/*"],
      "@integrated-tests/*": ["apps/integrated-tests/src/*"]
    }
  }
} 