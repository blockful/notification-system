{
  "name": "notification-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "codegen": "turbo run codegen --filter=@notification-system/anticapture-client",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "dev": "docker-compose up --build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "client": "turbo run --filter=@notification-system/anticapture-client",
    "consumer": "turbo run --filter=@notification-system/consumer",
    "dashboard": "turbo run --filter=@notification-system/dashboard",
    "dispatcher": "turbo run --filter=@notification-system/dispatcher",
    "flow-editor": "turbo run --filter=@notification-system/flow-editor",
    "integrated-tests": "turbo run --filter=@notification-system/integrated-tests",
    "logic-system": "turbo run --filter=@notification-system/logic-system",
    "messages": "turbo run --filter=@notification-system/messages",
    "rabbitmq-client": "turbo run --filter=@notification-system/rabbitmq-client",
    "subscription-server": "turbo run --filter=@notification-system/subscription-server"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "pg": "^8.16.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.5",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=18"
  }
}
